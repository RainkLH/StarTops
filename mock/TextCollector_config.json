{
  "collector": {
    "name": "文本收集器",
    "version": "1.0.0",
    "enabled": true
  },
  "storage": {
    "output_dir": "/data/output",
    "file_prefix": "collected_",
    "max_file_size": 10485760,
    "rotate_count": 5
  },
  "filters": {
    "min_length": 10,
    "max_length": 10000,
    "encoding": "utf-8",
    "exclude_patterns": []
  }
}
